{
  "extends": [
    ":dependencyDashboard",
    ":semanticPrefixFixDepsChoreOthers",
    ":ignoreModulesAndTests",
    "group:monorepos",
    "group:recommended",
    "mergeConfidence:age-confidence-badges",
    "replacements:all",
    "workarounds:all"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^apps/.*/.*\\.yaml$/",
        "/^infrastructure/system-upgrade/system-upgrade-controller\\.yaml$/"
      ],
      "matchStrings": [
        "image: (?<depName>.*?):(?<currentValue>.*)",
        "SYSTEM_UPGRADE_JOB_KUBECTL_IMAGE: (?<depName>.*?):(?<currentValue>.*)"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^infrastructure/system-upgrade/plans\\.yaml$/"
      ],
      "matchStrings": [
        "version: (?<currentValue>v\\d+\\.\\d+\\.\\d+\\+k3s\\d+)"
      ],
      "depNameTemplate": "k3s-io/k3s",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "regex:^v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)\\+k3s(?<build>\\d+)$"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["lscr.io/linuxserver/transmission"],
      "versioning": "semver",
      "allowedVersions": "<8"
    },
    {
      "description": "k8s control planes cannot skip minors: one PR per minor hop, in order",
      "matchDepNames": ["k3s-io/k3s"],
      "separateMultipleMinor": true,
      "commitMessageTopic": "k3s"
    },
    {
      "description": "SUC manifests are vendored: the PR is a notification, re-vendor before merging",
      "matchPackageNames": ["rancher/system-upgrade-controller"],
      "prBodyNotes": [
        "⚠️ **Vendored manifests** — do not merge the tag bump alone. Re-download `crd.yaml` + `system-upgrade-controller.yaml` from the upstream release into `infrastructure/system-upgrade/` (see docs/upgrades.md, 'Upgrading the controller itself')."
      ]
    }
  ]
}
