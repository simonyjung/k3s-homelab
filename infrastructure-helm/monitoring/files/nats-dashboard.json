      "targets": [
        {
          "expr": "sum(rate(nats_varz_in_msgs[$__rate_interval]))",
          "legendFormat": "in msgs/s",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "sum(rate(nats_varz_out_msgs[$__rate_interval]))",
          "legendFormat": "out msgs/s",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "mps",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
